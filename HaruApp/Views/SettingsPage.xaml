<phone:PhoneApplicationPage
    x:Class="HaruApp.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:shell="clr-namespace:Microsoft.Phone.Shell;assembly=Microsoft.Phone"
    xmlns:toolkit="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone.Controls.Toolkit"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    FontFamily="{StaticResource PhoneFontFamilyNormal}"
    FontSize="{StaticResource PhoneFontSizeNormal}"
    Foreground="{StaticResource PhoneForegroundBrush}"
    SupportedOrientations="Portrait"
    Orientation="Portrait"
    mc:Ignorable="d"
    shell:SystemTray.IsVisible="True"
    Style="{StaticResource TurnstilePageTransition}"
    toolkit:TiltEffect.IsTiltEnabled="True">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="12,17,0,28">
            <TextBlock Text="{Binding LocalizedResources.AppTitle, Source={StaticResource LocalizedStrings}}"
                       Style="{StaticResource PhoneTextNormalStyle}"/>
            <TextBlock Text="{Binding LocalizedResources.PageSettings, Source={StaticResource LocalizedStrings}}"
                       Margin="9,-7,0,0"
                       Style="{StaticResource PhoneTextTitle1Style}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      Margin="12,0,12,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <toolkit:ListPicker x:Name="TemperatureUnitListPicker"
                                    Grid.Row="0"
                                    Header="{Binding LocalizedResources.SettingTemperatureUnit, Source={StaticResource LocalizedStrings}}">
                    <sys:String>celsius</sys:String>
                    <sys:String>fahrenheit</sys:String>
                </toolkit:ListPicker>

                <toolkit:ListPicker x:Name="WindSpeedUnitListPicker"
                                    Grid.Row="1"
                                    Header="{Binding LocalizedResources.SettingWindSpeedUnit, Source={StaticResource LocalizedStrings}}">
                    <sys:String>kmh</sys:String>
                    <sys:String>ms</sys:String>
                    <sys:String>mph</sys:String>
                    <sys:String>kn</sys:String>
                </toolkit:ListPicker>

                <toolkit:ListPicker x:Name="PrecipitationUnitListPicker"
                                    Grid.Row="2"
                                    Header="{Binding LocalizedResources.SettingPrecipitationUnit, Source={StaticResource LocalizedStrings}}">
                    <sys:String>mm</sys:String>
                    <sys:String>inch</sys:String>
                </toolkit:ListPicker>

                <StackPanel Grid.Row="3">
                    <toolkit:ToggleSwitch x:Name="BackgroundUpdateToggleSwitch"
                                          Margin="0,12,-22,-12"
                                          Header="{Binding LocalizedResources.SettingBackgroundUpdates, Source={StaticResource LocalizedStrings}}"
                                          Checked="MasterToggle_Checked"
                                          Unchecked="MasterToggle_Unchecked"/>

                    <toolkit:ToggleSwitch x:Name="LiveTileToggleSwitch"
                                          Margin="0,0,-22,-12"
                                          Header="{Binding LocalizedResources.SettingLiveTile, Source={StaticResource LocalizedStrings}}"
                                          Checked="ChildToggle_Checked"
                                          Unchecked="ChildToggle_Unchecked"/>

                    <toolkit:ToggleSwitch x:Name="MonochromeTileToggleSwitch"
                                          Margin="0,0,-22,-12"
                                          Header="{Binding LocalizedResources.SettingMonochromeTile, Source={StaticResource LocalizedStrings}}"/>

                    <toolkit:ToggleSwitch x:Name="NotificationToggleSwitch"
                                          Margin="0,0,-22,-12"
                                          Header="{Binding LocalizedResources.SettingNotifications, Source={StaticResource LocalizedStrings}}"
                                          Checked="ChildToggle_Checked"
                                          Unchecked="ChildToggle_Unchecked"/>
                </StackPanel>

                <StackPanel Grid.Row="4"
                            Margin="0,0,0,0">
                    <Button x:Name="ClearSavedForecastButton"
                            Content="{Binding LocalizedResources.SettingClearForecast, Source={StaticResource LocalizedStrings}}"
                            Click="ClearSavedForecastButton_Click"/>
                    <TextBlock Margin="12,12,12,0"
                               FontFamily="{StaticResource PhoneFontFamilyNormal}"
                               FontSize="{StaticResource PhoneFontSizeMedium}"
                               TextWrapping="Wrap"
                               Text="{Binding LocalizedResources.SettingClearForecastDescription, Source={StaticResource LocalizedStrings}}"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>

</phone:PhoneApplicationPage>